# =============================================================================
# CQPM Nador — Environment variables
# =============================================================================
# LOCAL (PC):     copy to .env → use localhost DATABASE_URL
# VERCEL (cloud): set each KEY in Vercel Dashboard → Environment Variables
#                 use Neon connection string for DATABASE_URL (NOT localhost)
# =============================================================================

# --- Database ---
# Local PC:
# DATABASE_URL="postgresql://postgres:password@localhost:5432/cqpm?schema=public"
# Vercel / Neon (cloud only — paste from Neon → Connect):
# DATABASE_URL="postgresql://USER:PASS@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"
DATABASE_URL="postgresql://postgres:password@localhost:5432/cqpm?schema=public"

# --- NextAuth ---
# Generate: openssl rand -base64 32  (use a NEW secret for Vercel production)
AUTH_SECRET="generate-with-openssl-rand-base64-32"
# Local: http://localhost:3000  |  Vercel: https://your-project.vercel.app
AUTH_URL="http://localhost:3000"

# --- UploadThing (optional) ---
UPLOADTHING_TOKEN=""
UPLOADTHING_APP_ID=""

# --- Email / Resend (optional) ---
RESEND_API_KEY=""
CONTACT_EMAIL="contact@cqpm-nador.ma"
FROM_EMAIL="noreply@cqpm-nador.ma"

# --- Site ---
# Local: http://localhost:3000  |  Vercel: https://your-project.vercel.app
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_GOOGLE_MAPS_EMBED_URL="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3239.0!2d-2.927!3d35.168!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zMzXCsDEwJzA1LjAiTiAywrA1NSczNy4yIlc!5e0!3m2!1sfr!2sma!4v1"

# --- NanoBanana AI images (optional) ---
# NANOBANANA_API_KEY=""
# NANOBANANA_API_URL="https://api.nanobanana.dev/v1"

# --- Rate limiting (optional Redis) ---
# UPSTASH_REDIS_REST_URL=""
# UPSTASH_REDIS_REST_TOKEN=""
